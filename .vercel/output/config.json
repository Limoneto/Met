{
  "version": 3,
  "routes": [
    {
      "src": "^/bo/(.*)",
      "dest": "/bo/index.html"
    },
    {
      "src": "^/socio/(.*)",
      "dest": "/socio/index.html"
    },
    {
      "src": "^/kiosk/(.*)",
      "dest": "/kiosk/index.html"
    },
    {
      "src": "^/((?!bo|socio|kiosk|assets).*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.+)",
      "dest": "/static/$1"
    }
  ]
}