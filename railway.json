{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": null
  },
  "deploy": {
    "startCommand": "pnpm --filter @met/api start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "environmentVariables": {
    "NODE_ENV": "production",
    "PORT": "4000"
  }
}
